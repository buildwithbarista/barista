# barista user config — generated by `barista dial-in`.
#
# This is the user-level layer (~/.barista/config.toml). It is merged with
# project-level barista.toml, ~/.m2/settings.xml, BARISTA_* env vars, and CLI
# flags by `barista-config`. Anything below can be overridden per-project.
#
# Onboarding answers:
#   mirror-url     = "https://repo.maven.apache.org/maven2"
#   (Mirrors are honored via ~/.m2/settings.xml; see Maven docs for the
#   <mirrors> block. dial-in records your choice here for reference.)
#   use-roastery   = false
#   strict-default = false

[network]
max-concurrent-connections = <REDACTED>
